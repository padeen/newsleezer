<.header>
  <%= for html_tag <- ~w[section aside article h1 h2 h3 p a] do %>
    <.link
      class="bg-blue-500 hover:bg-blue-700
text-white font-bold py-2 px-4 border border-blue-700 rounded m-1"
      phx-click="select_html_tags"
      phx-value-html_tags={html_tag}
    >
      <%= html_tag %>
    </.link>
  <% end %>
  <p>Example websites</p>
  <p>https://schaken.nl</p>
  <p>https://nos.nl</p>
  <.simple_form for={@form} phx-change="validate" phx-submit="save">
    <.input field={@form[:url]} type="text" label="Type website url" phx-debounce="blur" />
    <:actions>
      <.button>Show website</.button>
    </:actions>
  </.simple_form>
</.header>

<%= for content <- @content do %>
  <%= if block_element?(content) do %>
    <p><%= "section - #{elem(content, 1)}" %></p>
  <% else %>
    <p><%= elem(content, 1) %></p>
  <% end %>
<% end %>
